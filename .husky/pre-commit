#!/bin/bash

# Fast local pre-commit gate.
# Heavier checks (full build, Docker verification, Playwright visuals) run in CI.
# To run the strict gate locally: `pnpm precheck`.

echo "🚀 Running pre-commit checks..."

pnpm exec lint-staged || { echo "❌ lint-staged failed."; exit 1; }
pnpm test:run || { echo "❌ Vitest failed."; exit 1; }

echo "✅ Pre-commit checks passed."
