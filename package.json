    "docker:sh": "docker run --rm -it --entrypoint=/bin/sh personal_website",
    "verify-docker": "scripts/verify_docker.sh",
    "type-check": "tsc --noEmit",
    "lint": "eslint .",
    "prepare": "husky"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
